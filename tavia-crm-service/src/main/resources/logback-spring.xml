<?xml version="1.0" encoding="UTF-8"?>
<!--
  TAVIA V2 — Centralized Logback Configuration
  ==============================================
  Log Routing Strategy:
    • INFO / DEBUG / WARN  →  logs/${SERVICE_NAME}.log
    • ERROR               →  logs/errors/${SERVICE_NAME}-error.log
    • All levels          →  STDOUT (console)

  Uses Spring Boot's logback-spring.xml extension to resolve
  ${spring.application.name} at bootstrap time.
-->
<configuration>

    <!-- Resolve service name from Spring Boot application config -->
    <springProperty scope="context" name="SERVICE_NAME"
                    source="spring.application.name"
                    defaultValue="tavia-service"/>

    <!-- Shared log directory (relative to project root where gradlew runs) -->
    <property name="LOG_DIR" value="logs"/>
    <property name="ERROR_LOG_DIR" value="logs/errors"/>

    <!-- ─── Log Pattern ───────────────────────────────────────────── -->
    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} — %msg%n"/>

    <!-- ─── CONSOLE Appender ──────────────────────────────────────── -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- ─── STANDARD FILE Appender (INFO, DEBUG, WARN) ────────────── -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/${SERVICE_NAME}.log</file>

        <!-- Only accept non-ERROR levels -->
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>DENY</onMatch>
            <onMismatch>ACCEPT</onMismatch>
        </filter>

        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>

        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/archive/${SERVICE_NAME}-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- ─── ERROR FILE Appender (ERROR only) ──────────────────────── -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${ERROR_LOG_DIR}/${SERVICE_NAME}-error.log</file>

        <!-- Only accept ERROR level -->
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>

        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>

        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${ERROR_LOG_DIR}/archive/${SERVICE_NAME}-error-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>20MB</maxFileSize>
            <maxHistory>60</maxHistory>
            <totalSizeCap>500MB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- ─── Root Logger ───────────────────────────────────────────── -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
        <appender-ref ref="ERROR_FILE"/>
    </root>

</configuration>
