# EXPO_PUBLIC_API_URL — Uncomment and set to override automatic gateway resolution.
# When running via Expo Go, the base URL is auto-resolved from debuggerHost (LAN IP:8080).
# Only set this for staging/tunnel scenarios (e.g., localtunnel, ngrok).
# EXPO_PUBLIC_API_URL=http://192.168.1.X:8080
# ADB Reverse Tunnel — Set to true when using adb reverse tcp:8080 tcp:8080
# Forces base URL to http://localhost:8080 on Android, bypassing LAN IP resolution.
EXPO_PUBLIC_USE_ADB_TUNNEL=true

# Force Expo to use a port that doesn't conflict with tavia-tenant-service (8081)
PORT=19000
