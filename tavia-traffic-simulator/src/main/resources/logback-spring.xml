<?xml version="1.0" encoding="UTF-8"?>
<!--
  TAVIA V2 — Simplified Logback Configuration
  ==============================================
  All logs are routed to STDOUT and a single file for simplicity.
  Trace/Correlation IDs are included per project-srs.md guidelines.
-->
<configuration>
    <springProperty scope="context" name="SERVICE_NAME"
                    source="spring.application.name"
                    defaultValue="tavia-service"/>

    <property name="LOG_DIR" value="logs"/>
    
    <!-- Sector Standard Pattern: Includes TraceID for Observability -->
    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [traceId=%X{traceId:-}, spanId=%X{spanId:-}] %logger{36} — %msg%n"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/${SERVICE_NAME}.log</file>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/archive/${SERVICE_NAME}-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>
</configuration>
